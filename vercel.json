{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run prisma:generate && next build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "crons": [
    { "path": "/api/cron/marketplace-auctions", "schedule": "*/10 * * * *" },
    { "path": "/api/cron/lottery-draw", "schedule": "*/15 * * * *" },
    { "path": "/api/cron/course-live-classes", "schedule": "*/15 * * * *" },
    { "path": "/api/cron/task-expiry", "schedule": "0 * * * *" },
    { "path": "/api/cron/course-reminders", "schedule": "0 9 * * *" },
    { "path": "/api/cron/subscription-expiry", "schedule": "0 0 * * *" }
  ]
}
