// Reference data backing the cascading address dropdowns. Seeded once and
// editable by admin. User profile address fields stay as flat string columns
// — these tables only drive the dropdown UI; they don't replace the User
// fields.
model Country {
  id            String     @id @default(cuid())
  iso2          String     @unique
  iso3          String?    @unique
  name          String     @unique
  phoneCode     String?
  flag          String?
  currency      String?
  isActive      Boolean    @default(true)
  // Which dropdown levels render for this country, in user-facing order.
  // E.g. BD = ["DIVISION","DISTRICT","SUB_DISTRICT","CITY"], US = ["STATE","CITY"].
  // Empty = no DB-backed dropdowns; all address fields fall back to free text.
  enabledLevels String[]   @default([])
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  locations     Location[]
  @@index([isActive, name])
}

model Location {
  id          String     @id @default(cuid())
