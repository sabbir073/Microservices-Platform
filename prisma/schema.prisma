  isAnnouncement   Boolean   @default(false)
  // Admin-set PROMOTED post. Appears with a PROMOTED badge and is
  // interleaved through the feed. Auto-expires when promotedUntil < now().
  isPromoted       Boolean   @default(false)
  promotedUntil    DateTime?
  // Optional sponsor name shown next to the PROMOTED badge (e.g. "NordVPN").
  promotedNote     String?   @db.VarChar(120)
