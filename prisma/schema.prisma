// Records each admin "bulk-add followers" operation. Used for audit and
// one-click undo (delete all Follow rows tagged with this batch id).
model FollowerBoostBatch {
  id             String   @id @default(cuid())
  targetUserId   String
  target         User     @relation("FollowerBoostTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  criteria       Json                              // saved filter snapshot
  mode           String                            // "ALL" or "RANDOM"
  requestedCount Int                               // sample size requested
  addedCount     Int      @default(0)              // actually-created Follow rows
  // The user ids that this batch added as followers. Persisted independently
  // of Follow rows so that a revert (which deletes the Follow rows) still
  // remembers who was added — those users are then permanently excluded
  // from future boost runs for the same target.
  sourceUserIds  String[] @default([])
  notifyTarget   Boolean  @default(false)          // if true, target got 1 combined notification
  performedBy    String?                           // admin user id
  status         String   @default("APPLIED")      // APPLIED | REVERTED
  revertedAt     DateTime?
  revertedBy     String?
  createdAt      DateTime @default(now())
  follows        Follow[]
  @@index([targetUserId, createdAt])
  @@index([status])
}

