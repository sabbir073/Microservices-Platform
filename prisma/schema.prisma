// EarnGPT Database Schema
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  TUTOR
  SUPER_ADMIN
  FINANCE_ADMIN
  CONTENT_ADMIN
  SUPPORT_ADMIN
  MARKETING_ADMIN
  MODERATOR
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
  PENDING_VERIFICATION
}

enum KYCStatus {
  NOT_SUBMITTED
  PENDING
  APPROVED
  REJECTED
}

enum TaskType {
  VIDEO
  ARTICLE
  QUIZ
  SURVEY
  SOCIAL
  PROXY
  OFFERWALL
  CUSTOM
}

enum TaskStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  EXPIRED
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
  AUTO_APPROVED
  REVISION_REQUESTED
}

enum TransactionType {
  EARNING
  WITHDRAWAL
  BONUS
  REFERRAL
  PURCHASE
  REFUND
  PENALTY
  GIFT
  LOTTERY_WIN
  CHECKIN
  COURSE_PURCHASE
  COURSE_TUTOR_EARNING
  COURSE_REFUND
  DEPOSIT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  COMPLETED
  REJECTED
  CANCELLED
}

enum PaymentMethod {
  BKASH
  NAGAD
  ROCKET
  BINANCE
  PAYPAL
}

// PackageTier enum removed in 2026-05 migration — use Package model + accessLevel instead.

enum TaskDifficulty {
  EASY
  MEDIUM
  HARD
}

enum QuizStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum BannerLocation {
  HOME
  EARN_HUB
  MARKETPLACE
  DASHBOARD
  ALL
}

model Banner {
  id          String         @id @default(cuid())
  title       String
  subtitle    String?
  imageUrl    String?
  videoUrl    String?        // optional background video (takes precedence over imageUrl)
  iconEmoji   String?
  bgGradient  String?        // e.g. "from-blue-600 to-purple-600"
  linkUrl     String?
  location    BannerLocation @default(HOME)
  order       Int            @default(0)
  isActive    Boolean        @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  createdById String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([location])
  @@index([isActive])
  @@index([order])
  @@index([isActive, location])
}

model Campaign {
  id              String   @id @default(cuid())
  title           String
  description     String?  @db.Text
  type            String   // XP_MULTIPLIER | BONUS_POINTS | FREE_TICKETS | DISCOUNT | REFERRAL_BOOST | SEASONAL
  value           Float    @default(1)
  startDate       DateTime
  endDate         DateTime
  targetType      String   @default("ALL") // ALL | TIER | NEW_USERS | COUNTRY
  targetValue     String?
  budget          Float?
  bannerImage     String?
  termsAndConditions String? @db.Text
  status          String   @default("SCHEDULED") // SCHEDULED | ACTIVE | PAUSED | ENDED
  participantCount Int     @default(0)
  rewardsDistributed Float @default(0)
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([startDate, endDate])
}

model Mission {
  id            String   @id @default(cuid())
  title         String
  description   String?  @db.Text
  type          String   // TASK_COMPLETION | LOGIN_STREAK | REFERRAL | SPEND | EARN
  targetValue   Int
  pointsReward  Int      @default(0)
  cashReward    Float    @default(0)
  xpReward      Int      @default(0)
  duration      String   @default("DAILY") // DAILY | WEEKLY
  autoRefresh   Boolean  @default(true)
  requiredLevel Int      @default(1)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive])
  @@index([duration])
}

// Daily Task Mission — admin-defined per-package mission template that bundles
// several "complete N tasks of type X" buckets. Users see today's mission for
// their tier, work through every bucket, then claim the final reward.
model DailyMissionTemplate {
  id                      String      @id @default(cuid())
  name                    String
  description             String?     @db.Text
  requiredAccessLevel     Int         @default(0)
  requiredLevel           Int         @default(1)
  completionXpReward      Int         @default(0)
  completionPointsReward  Int         @default(0)
  isActive                Boolean     @default(true)
  autoRefresh             Boolean     @default(true)
  linkReferralBonus       Boolean     @default(false)
  order                   Int         @default(0)
  createdById             String?
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  items   DailyMissionItem[]
  claims  DailyMissionClaim[]

  @@index([requiredAccessLevel])
  @@index([isActive])
}

model DailyMissionItem {
  id                String               @id @default(cuid())
  missionId         String
  mission           DailyMissionTemplate @relation(fields: [missionId], references: [id], onDelete: Cascade)
  taskType          String               // ARTICLE | VIDEO | QUIZ | SURVEY | SOCIAL | PROXY | OFFERWALL | BOARD | MANUAL | CUSTOM
  description       String?              @db.Text
  targetCount       Int                  @default(1)
  xpPerComplete     Int                  @default(0)
  pointsPerComplete Int                  @default(0)
  duration          Int?                 // minutes (display-only)
  requiredLevel     Int?
  order             Int                  @default(0)

  @@index([missionId])
}

model DailyMissionClaim {
  id          String                @id @default(cuid())
  userId      String
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  missionId   String
  mission     DailyMissionTemplate  @relation(fields: [missionId], references: [id], onDelete: Cascade)
  date        String                // YYYY-MM-DD (UTC)
  streak      Int                   @default(1)
  claimedAt   DateTime              @default(now())

  @@unique([userId, missionId, date])
  @@index([userId, date])
  @@index([missionId])
}

model DailyReferralClaim {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String   // YYYY-MM-DD (UTC)
  amount    Float
  points    Int
  claimedAt DateTime @default(now())

  @@unique([userId, date])
  @@index([userId])
}

model AdCampaign {
  id            String   @id @default(cuid())
  advertiserId  String?
  title         String
  description   String?  @db.Text
  budget        Float    @default(0)
  status        String   @default("ACTIVE") // ACTIVE | PAUSED | ENDED
  ads           Ad[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([advertiserId])
  @@index([status])
}

model AdPlacement {
  id        String   @id @default(cuid())
  name      String   @unique
  platform  String   @default("ALL")
  isActive  Boolean  @default(true)
  ads       Ad[]
  createdAt DateTime @default(now())
}

model AdNetwork {
  id              String   @id @default(cuid())
  name            String
  providerKey     String   @unique
  initScript      String?  @db.Text
  isEnabledWeb    Boolean  @default(true)
  isEnabledMobile Boolean  @default(true)
  globalWeight    Int      @default(10)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Ad {
  id          String      @id @default(cuid())
  campaignId  String
  campaign    AdCampaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  placementId String
  placement   AdPlacement @relation(fields: [placementId], references: [id])
  type        String      @default("LOCAL")
  format      String      @default("BANNER")
  contentUrl  String?
  targetUrl   String?
  htmlContent String?     @db.Text
  weight      Int         @default(10)
  status      String      @default("ACTIVE")
  impressions Int         @default(0)
  clicks      Int         @default(0)
  // Viewer-reward (watch-and-earn)
  rewardPoints      Int    @default(0)
  rewardCooldownSec Int    @default(3600)
  watchSeconds      Int    @default(15)
  views       AdView[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([campaignId])
  @@index([placementId])
  @@index([status])
}

model AdView {
  id             String   @id @default(cuid())
  userId         String
  adId           String
  ad             Ad       @relation(fields: [adId], references: [id], onDelete: Cascade)
  rewardedPoints Int      @default(0)
  createdAt      DateTime @default(now())

  @@index([userId, adId])
  @@index([userId, createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

model Deposit {
  id         String   @id @default(cuid())
  userId     String
  amount     Float
  method     String   // MANUAL_BKASH | MANUAL_NAGAD | SSLCOMMERZ | ...
  status     String   @default("PENDING") // PENDING | APPROVED | REJECTED
  gatewayRef String?
  txnId      String?
  proofUrl   String?
  adminNote  String?
  reviewedBy String?
  reviewedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

enum FraudSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model FraudEvent {
  id          String        @id @default(cuid())
  userId      String?
  eventType   String   // MULTIPLE_ACCOUNTS, VPN_DETECTED, etc.
  severity    FraudSeverity @default(MEDIUM)
  details     Json?
  ipAddress   String?
  userAgent   String?
  status      String   @default("OPEN") // OPEN | DISMISSED | ACTED
  resolverNote String? @db.Text
  resolvedById String?
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([eventType])
  @@index([severity])
  @@index([status])
  @@index([createdAt])
}

model ProxyServer {
  id              String   @id @default(cuid())
  name            String
  host            String
  port            Int
  protocol        String   @default("HTTPS") // HTTP | HTTPS | SOCKS5
  country         String?  // ISO code
  status          String   @default("ACTIVE") // ACTIVE | INACTIVE | ERROR
  loadPercent     Int      @default(0)
  maxConcurrent   Int      @default(50)
  bandwidthMbUser Int      @default(100)
  responseTimeMs  Int?
  lastHealthCheck DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([country])
}

model OfferwallCallback {
  id            String   @id @default(cuid())
  userId        String
  offerwallId   String
  offerId       String?
  offerName     String?
  transactionId String   @unique
  payoutAmount  Float
  userPayout    Int     // points
  currency      String   @default("USD")
  status        String   @default("PENDING") // PENDING | APPROVED | REJECTED | FRAUD | CHARGEBACK
  fraudScore    Int     @default(0)
  fraudReasons  String[]
  ipAddress     String?
  userAgent     String?  @db.Text
  countryCode   String?
  deviceType    String?
  rawPayload    Json?
  reviewedById  String?
  reviewNote    String?  @db.Text
  rejectionReason String? @db.Text
  processedAt   DateTime?
  creditedAt    DateTime?
  createdAt     DateTime @default(now())

  @@index([status])
  @@index([offerwallId])
  @@index([userId])
  @@index([createdAt])
}

model TaskBoard {
  id           String   @id @default(cuid())
  title        String
  description  String?  @db.Text
  iconEmoji    String?
  imageUrl     String?
  // "Marketing" | "Development" | "Design" | "Sales" | "Learning" | "Other"
  category     String?
  // null = no deadline
  expiresAt    DateTime?
  pointsReward Int      @default(0)
  xpReward     Int      @default(0)
  isActive     Boolean  @default(true)
  order        Int      @default(0)
  // Optional prerequisite board — user must claim this board first to unlock.
  unlockBoardId String?
  unlockBoard   TaskBoard?  @relation("BoardUnlockChain", fields: [unlockBoardId], references: [id], onDelete: SetNull)
  unlocks       TaskBoard[] @relation("BoardUnlockChain")
  createdById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tasks   Task[]
  claims  BoardClaim[]

  @@index([isActive])
  @@index([order])
  @@index([category])
  @@index([unlockBoardId])
}

// Per-user record of a Task Board reward claim. One row per (user, board);
// uniqueness enforced at the DB level so re-claims are impossible regardless
// of races. Created inside the same transaction as the EARNING transaction
// so the two stay consistent.
model BoardClaim {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  boardId       String
  board         TaskBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  pointsEarned  Int       @default(0)
  xpEarned      Int       @default(0)
  taskCount     Int       @default(0)
  claimedAt     DateTime  @default(now())
  transactionId String?

  @@unique([userId, boardId])
  @@index([boardId, claimedAt])
  @@index([userId])
}

model SocialReport {
  id          String   @id @default(cuid())
  contentType String   // POST | COMMENT | USER | LISTING
  contentId   String
  reporterId  String
  reason      String   // SPAM | HARASSMENT | FRAUD | INAPPROPRIATE | OTHER
  details     String?  @db.Text
  priority    String   @default("NORMAL") // URGENT | HIGH | NORMAL
  status      String   @default("PENDING") // PENDING | RESOLVED
  resolution  String?  // DISMISSED | WARNED | SUSPENDED | BANNED | DELETED
  resolverNote String? @db.Text
  resolvedById String?
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([status])
  @@index([contentType])
  @@index([reporterId])
  @@index([createdAt])
}

model Quiz {
  id              String         @id @default(cuid())
  title           String
  description     String?        @db.Text
  category        String         @default("General")
  difficulty      TaskDifficulty @default(MEDIUM)
  status          QuizStatus     @default(DRAFT)
  timeLimitSec    Int            @default(180)
  passingScore    Int            @default(60)
  pointsReward    Int            @default(50)
  xpReward        Int            @default(25)
  cashReward      Float          @default(0)
  maxAttempts     Int            @default(3)
  cooldownHours   Int            @default(24)
  requiredLevel   Int            @default(1)
  requiredAccessLevel Int?
  questions       QuizQuestion[]
  aiGenerated     Boolean        @default(false)
  aiPrompt        String?        @db.Text
  createdById     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  attempts        QuizAttempt[]

  @@index([status])
  @@index([category])
  @@index([difficulty])
}

model QuizQuestion {
  id            String   @id @default(cuid())
  quizId        String
  quiz          Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  order         Int      @default(0)
  question      String   @db.Text
  options       String[]
  correctIndex  Int
  explanation   String?  @db.Text
  pointsValue   Int      @default(10)

  @@index([quizId])
}

model QuizAttempt {
  id          String    @id @default(cuid())
  quizId      String
  quiz        Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)
  userId      String
  score       Int       @default(0)
  passed      Boolean   @default(false)
  answers     Json      // user's answers per question
  timeTakenSec Int      @default(0)
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([quizId])
  @@index([userId])
  @@index([completedAt])
}

enum MarketplaceListingStatus {
  ACTIVE
  SOLD
  CANCELLED
  EXPIRED
}

enum MarketplaceBidStatus {
  ACTIVE // current high bid (only one ACTIVE per listing)
  OUTBID // a later, higher bid replaced this one
  WON    // auction closed and this bid won
  LOST   // auction closed and this bid didn't win
  CANCELLED
}

enum MarketplaceOfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  COUNTERED
  EXPIRED
  WITHDRAWN
}

enum CourseStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  SUSPENDED
  ARCHIVED
}

enum CourseSkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ALL_LEVELS
}

enum CourseLessonType {
  VIDEO
  ARTICLE
  QUIZ
  ASSIGNMENT
  LIVE
  RESOURCE
}

enum QuizQuestionType {
  MCQ
  TRUE_FALSE
  MULTI_SELECT
}

enum AssignmentSubmissionStatus {
  PENDING
  GRADED
  RESUBMIT
}

enum LiveClassStatus {
  UPCOMING
  LIVE
  ENDED
  CANCELLED
}

enum CourseRefundStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CouponType {
  PERCENT
  FIXED
}

enum CouponScope {
  ALL
  CATEGORY
  SPECIFIC_COURSES
}

enum TutorApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LotteryStatus {
  UPCOMING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum NotificationType {
  SYSTEM
  TASK
  WALLET
  REFERRAL
  PROMOTION
  ACHIEVEMENT
  LOTTERY
  SOCIAL
  COURSE
}
model User {
  id                String      @id @default(cuid())
  email             String      @unique
  emailVerified     DateTime?
  phone             String?
  phoneVerified     DateTime?
  password          String?
  name              String?
  firstName         String?
  lastName          String?
  username          String?     @unique
  avatar            String?
  coverPhoto        String?
  bio               String?
  country           String?
  timezone          String?     @default("UTC")
  role              UserRole    @default(USER)
  status            UserStatus  @default(PENDING_VERIFICATION)
  pointsBalance     Int         @default(0)
  cashBalance       Float       @default(0)
  totalEarnings     Float       @default(0)
  totalWithdrawals  Float       @default(0)
  xp                Int         @default(0)
  level             Int         @default(1)
  streak            Int         @default(0)
  lastCheckIn       DateTime?
  packageId         String?
  package           Package?    @relation(fields: [packageId], references: [id], onDelete: SetNull)
  packageExpiresAt  DateTime?
  kycStatus         KYCStatus   @default(NOT_SUBMITTED)
  kycSubmittedAt    DateTime?
  kycApprovedAt     DateTime?
  isBlueVerified    Boolean     @default(false)
  // Visual style for the verified badge. Null/"BLUE" = classic blue tick.
  // Other presets (GOLD, RAINBOW, EMERALD, PURPLE, ROSE, OCEAN) render
  // a richer gradient — set by admin from the user-edit screen.
  verifiedBadgeStyle String?    @default("BLUE")
  twoFactorEnabled  Boolean     @default(false)
  twoFactorSecret   String?
  referralCode      String      @unique
  referredById      String?
  referredBy        User?       @relation("ReferralRelation", fields: [referredById], references: [id])
  referrals         User[]      @relation("ReferralRelation")
  // Extended profile fields (admin_oo.md §5.02)
  gender            String?
  dateOfBirth       DateTime?
  nidNumber         String?
  profession        String?
  maritalStatus     String?
  studyLevel        String?
  nationality       String?
  bloodGroup        String?
  secondaryEmail    String?
  secondaryPhone    String?
  // Extended address fields
  street            String?
  village           String?
  city              String?
  subDistrict       String?
  district          String?
  subDivision       String?
  division          String?
  region            String?
  postalCode        String?
  // Profile tags (Early Adopter / Crypto / Trader / Pro / etc.) — max 3 picked from a fixed set
  tags              String[]    @default([])
  // Settings
  theme             String      @default("dark")
  themeAccent       String?     @default("indigo")
  language          String      @default("en")
  notificationsEnabled Boolean  @default(true)
  emailNotifications Boolean    @default(true)
  pushNotifications  Boolean    @default(true)
  // Privacy visibility ("PUBLIC" | "FRIENDS" | "PRIVATE") — defaults match spec
  privacyAvatar     String      @default("PUBLIC")
  privacyBio        String      @default("PUBLIC")
  privacyStats      String      @default("PUBLIC")
  privacyEarnings   String      @default("PRIVATE")
  privacyLocation   String      @default("FRIENDS")
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  lastLoginAt       DateTime?
  accounts          Account[]
  sessions          Session[]
  kycDocuments      KYCDocument[]
  kycAppeals        KYCAppeal[]
  taskSubmissions   TaskSubmission[]
  transactions      Transaction[]
  withdrawals       Withdrawal[]
  paymentMethods    UserPaymentMethod[]
  notifications     Notification[]
  marketplaceListings MarketplaceListing[]
  marketplacePurchases MarketplacePurchase[]
  marketplaceWatches  MarketplaceWatch[]
  marketplaceViews    MarketplaceListingView[]
  marketplaceBids     MarketplaceBid[]
  marketplaceOffers   MarketplaceOffer[]
  courseEnrollments CourseEnrollment[]
  tutorProfile      TutorProfile?
  tutorApplications TutorApplication[]
  tutorApplicationsReviewed TutorApplication[] @relation("TutorAppReviewer")
  coursesTaught     Course[]              @relation("CourseTutor")
  courseReviews     CourseReview[]
  courseQuestionsAsked    CourseQuestion[]  @relation("CourseQuestionAsker")
  courseQuestionsAnswered CourseQuestion[]  @relation("CourseQuestionAnswerer")
  courseBookmarks   CourseBookmark[]
  courseAnnouncements CourseAnnouncement[]
  courseQuizAttempts  CourseQuizAttempt[]
  courseAssignmentSubmissions CourseAssignmentSubmission[]
  courseAssignmentSubmissionsGraded CourseAssignmentSubmission[] @relation("AssignmentGrader")
  courseCertificates  CourseCertificate[]
  courseCoupons       CourseCoupon[]
  courseRefundsRequested CourseRefundRequest[] @relation("CourseRefundUser")
  courseRefundsProcessed CourseRefundRequest[] @relation("CourseRefundAdmin")
  courseViews         CourseListingView[]
  lotteryTickets    LotteryTicket[]
  posts             Post[]
  comments          Comment[]
  likes             Like[]
  badges            UserBadge[]
  achievements      UserAchievement[]
  referralEarnings  ReferralEarning[]
  pointGifts        PointGift[]         @relation("PointGiftSender")
  receivedGifts     PointGift[]         @relation("PointGiftReceiver")
  mediaUploads      Media[]
  cartItems         CartItem[]
  votes             Vote[]
  donations         Donation[]
  ownedGroups       Group[]            @relation("GroupOwner")
  groupMemberships  GroupMember[]
  groupJoinRequests GroupJoinRequest[]
  dailyMissionClaims  DailyMissionClaim[]
  dailyReferralClaims DailyReferralClaim[]
  socialAccounts      SocialAccount[]
  // Native social graph
  followers          Follow[]    @relation("Followers")
  following          Follow[]    @relation("Following")
  followerBoostBatches FollowerBoostBatch[] @relation("FollowerBoostTarget")
  followersCount     Int         @default(0)
  followingCount     Int         @default(0)
  // Admin-set vanity offsets. Display = max(0, real + boost).
  // Can be negative (admin can lower the visible count).
  displayFollowersBoost Int       @default(0)
  displayFollowingBoost Int       @default(0)
  displayPostsBoost     Int       @default(0)
  postViews          PostView[]
  postShares         PostShare[]
  socialActions      SocialActionLog[]
  boardClaims        BoardClaim[]
  articleKeys        ArticleTaskKey[]
  mentionsReceived   Mention[]   @relation("Mentioned")
  mentionsMade       Mention[]   @relation("MentionedBy")
  @@index([email])
  @@index([referralCode])
  @@index([referredById])
  @@index([status])
  @@index([role])
  @@index([totalEarnings])
  @@index([referredById, createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
  @@index([userId])
}

// Connected social account — one row per (user × platform)
model SocialAccount {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform       String   // TWITTER | FACEBOOK | INSTAGRAM | YOUTUBE | TIKTOK | LINKEDIN | TELEGRAM | DISCORD
  username       String
  url            String?
  followers      Int      @default(0)
  following      Int      @default(0)
  postsCount     Int      @default(0)
  verified       Boolean  @default(false)
  connectedAt    DateTime @default(now())
  lastSyncedAt   DateTime?
  @@unique([userId, platform])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  type       String   @default("EMAIL")
  @@unique([identifier, token])
}

model KYCDocument {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentType String
  documentUrl String
  status      KYCStatus @default(PENDING)
  rejectionReason String?
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  appeals     KYCAppeal[]
  @@index([userId])
  @@index([status])
}

enum KYCAppealStatus {
  PENDING
  APPROVED
  REJECTED
}

model KYCAppeal {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  kycDocumentId  String
  kycDocument    KYCDocument     @relation(fields: [kycDocumentId], references: [id], onDelete: Cascade)
  reason         String          @db.Text
  evidence       String[]
  status         KYCAppealStatus @default(PENDING)
  adminNote      String?         @db.Text
  reviewedById   String?
  reviewedAt     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  @@index([userId])
  @@index([kycDocumentId])
  @@index([status])
  @@index([createdAt])
}

model Task {
  id              String       @id @default(cuid())
  title           String
  description     String       @db.Text
  instructions    String?      @db.Text
  instructionVideoUrl String?
  type            TaskType
  status          TaskStatus   @default(ACTIVE)
  difficulty      TaskDifficulty @default(MEDIUM)
  pointsReward    Int
  cashReward      Float        @default(0)
  xpReward        Int          @default(0)
  isBoardOnly     Boolean      @default(false)
  boardId         String?
  board           TaskBoard?   @relation(fields: [boardId], references: [id], onDelete: SetNull)
  dailyLimit      Int?
  totalLimit      Int?
  completedCount  Int          @default(0)
  minLevel        Int          @default(1)
  requiredAccessLevel Int      @default(0)
  countries       String[]     @default([])
  contentUrl      String?
  thumbnailUrl    String?
  duration        Int?
  questions       Json?
  socialPlatform  String?
  socialAction    String?
  socialUrl       String?
  socialConfig    Json?      // Platform×action specific config (see lib/social-tasks.ts SocialConfig)
  articleConfig   Json?      // Article task config (see lib/article-tasks.ts ArticleConfig)
  videoConfig     Json?      // Video task config (see lib/video-tasks.ts VideoConfig)
  surveyConfig    Json?      // Survey task config (see lib/survey-tasks.ts SurveyConfig)
  customConfig    Json?      // Custom task config (see lib/custom-tasks.ts CustomConfig)
  proxyInstructions String?    @db.Text
  startsAt        DateTime?
  expiresAt       DateTime?
  cooldownMinutes Int          @default(0)
  autoApprove     Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  createdById     String?
  submissions     TaskSubmission[]
  categories      TaskCategory[]
  // Article-task key-pool relations (only used when articleConfig.useKeyPool=true)
  articleKeys     ArticleTaskKey[]
  @@index([status])
  @@index([type])
  @@index([requiredAccessLevel])
  @@index([status, createdAt])
}

model TaskCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  icon        String?
  color       String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  tasks       Task[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TaskSubmission {
  id            String           @id @default(cuid())
  taskId        String
  task          Task             @relation(fields: [taskId], references: [id])
  userId        String
  user          User             @relation(fields: [userId], references: [id])
  status        SubmissionStatus @default(PENDING)
  proof         String?          @db.Text
  proofImages   String[]
  answers       Json?
  score         Int?
  reviewedBy    String?
  reviewedAt    DateTime?
  rejectionReason String?
  pointsEarned  Int?
  xpEarned      Int?
  // Type-specific proof bag — used by SOCIAL ({ socialUsername, socialGeneratedContent }),
  // forward-flexible for future task types.
  metadata      Json?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  // Article key-pool relations (only populated for ARTICLE tasks with useKeyPool=true)
  articleKey    ArticleTaskKey?
  pageProgress  ArticleTaskPageProgress[]
  @@unique([taskId, userId, createdAt])
  @@index([userId])
  @@index([taskId])
  @@index([status])
  @@index([userId, status])
  @@index([userId, createdAt])
}

// Pool of one-time-use unique keys for an ARTICLE task. Keys are claimed
// atomically by the cross-domain embed flow on the final article page; once
// claimed, the row is locked to the user + submission.
model ArticleTaskKey {
  id              String          @id @default(cuid())
  taskId          String
  task            Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  keyValue        String
  // Unclaimed when null. Set atomically when the user clicks "Generate Key"
  // on the final article page.
  claimedByUserId String?
  claimedByUser   User?           @relation(fields: [claimedByUserId], references: [id], onDelete: SetNull)
  claimedAt       DateTime?
  // Set when the user actually submits the key back to /api/tasks/:id/submit.
  submissionId    String?         @unique
  submission      TaskSubmission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)
  createdAt       DateTime        @default(now())

  @@unique([taskId, keyValue])
  @@index([taskId, claimedByUserId])
  @@index([claimedByUserId])
}

// Per-page popup completion progress. The embed script POSTs each completed
// popup; we increment the row. Page is "done" when popupsCompleted >=
// articleConfig.pages[pageIndex].popupCount.
model ArticleTaskPageProgress {
  id              String         @id @default(cuid())
  submissionId    String
  submission      TaskSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  pageIndex       Int
  popupsCompleted Int            @default(0)
  pageCompleted   Boolean        @default(false)
  completedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([submissionId, pageIndex])
  @@index([submissionId])
}

model Transaction {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id])
  type        TransactionType
  status      TransactionStatus @default(COMPLETED)
  points      Int               @default(0)
  amount      Float             @default(0)
  description String?
  reference   String?
  metadata    Json?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([userId, createdAt])
}

model Withdrawal {
  id              String           @id @default(cuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id])
  amount          Float
  fee             Float            @default(0)
  netAmount       Float
  method          PaymentMethod
  accountDetails  Json
  status          WithdrawalStatus @default(PENDING)
  processedBy     String?
  processedAt     DateTime?
  transactionId   String?
  rejectionReason String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([userId, status])
  @@index([status, createdAt])
}

model UserPaymentMethod {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  method        PaymentMethod
  accountNumber String
  accountName   String?
  isDefault     Boolean       @default(false)
  isVerified    Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  @@index([userId])
}

model Package {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  description     String?
  accessLevel     Int      @default(0)
  isDefault       Boolean  @default(false)

  // Pricing
  priceMonthly    Float
  priceYearly     Float?
  validityDays    Int?

  // Section-level feature toggles
  tasksEnabled        Boolean @default(true)
  socialFeedEnabled   Boolean @default(true)
  referralsEnabled    Boolean @default(true)
  withdrawalsEnabled  Boolean @default(true)
  marketplaceEnabled  Boolean @default(true)
  boostEnabled        Boolean @default(true)
  dailyMissionEnabled Boolean @default(true)
  lotteryEnabled      Boolean @default(true)
  coursesEnabled      Boolean @default(true)
  adFree              Boolean @default(false)

  // Per-task-type toggles
  socialTasksEnabled    Boolean @default(true)
  proxyTasksEnabled     Boolean @default(true)
  articleTasksEnabled   Boolean @default(true)
  videoTasksEnabled     Boolean @default(true)
  quizTasksEnabled      Boolean @default(true)
  surveyTasksEnabled    Boolean @default(true)
  offerwallTasksEnabled Boolean @default(true)

  // Limits
  dailyTaskLimit        Int   @default(-1)
  withdrawalFeeDiscount Float @default(0)
  minWithdrawal         Float

  // Multipliers
  xpMultiplier            Float @default(1)
  taskRewardMultiplier    Float @default(1)
  socialEarningMultiplier Float @default(1)
  dailyReferralPoints     Float @default(5)
  // Number of upline referral levels this plan unlocks. 0 = user can refer
  // but earns no commission at any level. 1 = L1 only. N = L1..L_N.
  referralCommissionLevels Int  @default(0)

  // Marketing
  features    String[]
  badgeColor  String?

  // System
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  subscriptions Subscription[]

  @@index([accessLevel])
  @@index([isDefault])
  @@index([isActive])
}

model Subscription {
  id            String      @id @default(cuid())
  userId        String
  packageId     String?
  package       Package?    @relation(fields: [packageId], references: [id], onDelete: SetNull)
  startDate     DateTime    @default(now())
  endDate       DateTime
  amount        Float
  paymentMethod PaymentMethod?
  transactionId String?
  isActive      Boolean     @default(true)
  autoRenew     Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  @@index([userId])
  @@index([isActive])
  @@index([packageId])
}

enum CommissionType {
  PERCENTAGE
  FLAT_RATE
}

model ReferralLevel {
  id              String         @id @default(cuid())
  level           Int            @unique
  commissionType  CommissionType @default(PERCENTAGE)
  commissionValue Float          @default(0)
  commissionRate  Float?         // Legacy field, will be migrated
  description     String?
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model ReferralEarning {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  referredUserId  String
  level           Int
  amount          Float
  sourceType      String
  sourceId        String?
  createdAt       DateTime @default(now())
  @@index([userId])
  @@index([createdAt])
  @@index([userId, createdAt])
}

model MarketplaceListing {
  id              String                   @id @default(cuid())
  sellerId        String
  seller          User                     @relation(fields: [sellerId], references: [id])
  title           String
  description     String                   @db.Text
  // Free-form category retained for back-compat (existing rows). New listings
  // should use assetType + subType instead. See src/lib/marketplace-categories.ts.
  category        String
  // Typed asset taxonomy. Drives the dynamic listing form + per-category
  // commission. Defaults to "DIGITAL_PRODUCT" so legacy rows stay valid.
  assetType       String                   @default("DIGITAL_PRODUCT")
  subType         String?
  // Category-specific structured data (mirrors customConfig pattern on Task).
  details         Json?
  price           Float
  currency        String                   @default("USD")
  images          String[]
  // Proof-of-asset screenshots (Search Console, analytics, ad dashboards,
  // payout history). Kept separate from `images` (which is the marketing gallery).
  screenshots     String[]
  // PDFs, traffic reports, P&L docs.
  attachments     String[]
  files           String[]
  // Long-form description (markdown). Short `description` stays for cards/list.
  richDescription String?                  @db.Text
  // Asset financials (where relevant — null for non-monetized assets).
  monthlyRevenue  Float?
  monthlyProfit   Float?
  monthlyExpenses Float?
  monthlyTraffic  Int?
  assetAgeMonths  Int?
  niche           String?
  reasonsForSelling String?                @db.Text
  whatsIncluded   String?                  @db.Text
  whatsNotIncluded String?                 @db.Text
  // Admin-set after reviewing proof screenshots. Surfaces a green badge.
  verifiedMetrics Boolean                  @default(false)
  // Adult / quarantined content. Hidden from default browsing.
  nsfw            Boolean                  @default(false)
  // Revenue figures hidden until buyer signs an NDA.
  ndaGated        Boolean                  @default(false)
  // Auction support. When false the listing is fixed-price buy-now only.
  auctionMode     Boolean                  @default(false)
  startingBid     Float?
  reservePrice    Float?
  buyNowPrice     Float?
  auctionEndsAt   DateTime?
  isFeatured      Boolean                  @default(false)
  featuredUntil   DateTime?
  isPromoted      Boolean                  @default(false)
  promotedUntil   DateTime?
  // Override platform commission in basis points (100 bps = 1%).
  // Falls back to setting `marketplace_commission_rates` when null.
  commissionRateBps Int?
  // Pre-aggregated counters for fast list rendering.
  bidsCount       Int                      @default(0)
  bidderCount     Int                      @default(0)
  uniqueViewers   Int                      @default(0)
  directPurchasesCount Int                 @default(0)
  status          MarketplaceListingStatus @default(ACTIVE)
  views           Int                      @default(0)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  expiresAt       DateTime?
  purchases       MarketplacePurchase[]
  cartItems       CartItem[]
  watches         MarketplaceWatch[]
  viewLog         MarketplaceListingView[]
  bids            MarketplaceBid[]
  offers          MarketplaceOffer[]
  @@index([sellerId])
  @@index([status])
  @@index([category])
  @@index([assetType])
  @@index([isFeatured])
}

model MarketplacePurchase {
  id          String             @id @default(cuid())
  listingId   String
  listing     MarketplaceListing @relation(fields: [listingId], references: [id])
  buyerId     String
  buyer       User               @relation(fields: [buyerId], references: [id])
  amount      Float
  fee         Float
  sellerAmount Float
  status      String             @default("COMPLETED")
  createdAt   DateTime           @default(now())
  disputes    MarketplaceDispute[]
  @@index([listingId])
  @@index([buyerId])
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1)
  addedAt   DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId])
}

// Users can "watch" listings — soft favorites that surface in seller analytics
// ("12 people are watching this listing").
model MarketplaceWatch {
  id        String             @id @default(cuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  watchedAt DateTime           @default(now())

  @@unique([userId, listingId])
  @@index([listingId])
  @@index([userId])
}

// Per-view audit row for marketplace listing analytics. The viewer can be
// anonymous (sessionHash dedupes). Phase-4 charts read from this table; the
// hot `uniqueViewers` counter on MarketplaceListing is incremented when this
// is the user's first row.
model MarketplaceListingView {
  id          String             @id @default(cuid())
  listingId   String
  listing     MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionHash String
  source      String?
  viewedAt    DateTime           @default(now())

  @@unique([listingId, sessionHash])
  @@index([listingId])
  @@index([viewedAt])
}

// A bid in an auction-mode listing. Only one ACTIVE bid exists per listing at
// any time; placing a higher bid moves the previous ACTIVE row to OUTBID and
// notifies the prior bidder.
model MarketplaceBid {
  id        String               @id @default(cuid())
  listingId String
  listing   MarketplaceListing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  bidderId  String
  bidder    User                 @relation(fields: [bidderId], references: [id], onDelete: Cascade)
  amount    Float
  status    MarketplaceBidStatus @default(ACTIVE)
  message   String?              @db.Text
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([listingId])
  @@index([bidderId])
  @@index([listingId, status])
}

// A "make an offer" submission. Independent of auction bids — a buyer can
// offer any amount; the seller accepts / rejects / counters. Accepting an
// offer turns it into a MarketplacePurchase at the agreed price.
model MarketplaceOffer {
  id            String                 @id @default(cuid())
  listingId     String
  listing       MarketplaceListing     @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyerId       String
  buyer         User                   @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  amount        Float
  message       String?                @db.Text
  status        MarketplaceOfferStatus @default(PENDING)
  counterAmount Float?
  counterMessage String?               @db.Text
  expiresAt     DateTime?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@index([listingId])
  @@index([buyerId])
  @@index([listingId, status])
}

model Course {
  id              String        @id @default(cuid())
  title           String
  slug            String?       @unique
  subtitle        String?
  description     String        @db.Text
  thumbnail       String?
  bannerUrl       String?
  promoVideoUrl   String?
  category        String
  categoryId      String?
  category_rel    CourseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  subcategoryId   String?
  subcategory_rel CourseSubcategory? @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  difficulty      String        @default("BEGINNER")
  skillLevel      CourseSkillLevel @default(BEGINNER)
  language        String        @default("en")
  price           Float         @default(0)
  originalPrice   Float?
  discountPrice   Float?
  discountEndsAt  DateTime?
  isFree          Boolean       @default(false)
  totalLessons    Int           @default(0)
  totalDuration   Int           @default(0)
  status          CourseStatus  @default(DRAFT)
  enrollmentCount Int           @default(0)
  rating          Float         @default(0)
  totalRatings    Int           @default(0)
  avgRating       Float         @default(0)
  totalReviews    Int           @default(0)
  totalQuestions  Int           @default(0)
  totalRevenueCents Int         @default(0)
  uniqueViewers   Int           @default(0)
  learningOutcomes String[]     @default([])
  requirements    String[]      @default([])
  whatsIncluded   String[]      @default([])
  faqs            Json?
  seoTitle        String?
  seoDescription  String?
  seoKeywords     String[]      @default([])
  tutorId         String?
  tutor           User?         @relation("CourseTutor", fields: [tutorId], references: [id], onDelete: SetNull)
  certificateEnabled Boolean    @default(true)
  commissionRateBps Int?
  isFeatured      Boolean       @default(false)
  featuredUntil   DateTime?
  isPromoted      Boolean       @default(false)
  promotedUntil   DateTime?
  nsfw            Boolean       @default(false)
  createdById     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  publishedAt     DateTime?
  lastContentUpdate DateTime?
  modules         CourseModule[]
  lessons         CourseLesson[]
  enrollments     CourseEnrollment[]
  reviews         CourseReview[]
  questions       CourseQuestion[]
  bookmarks       CourseBookmark[]
  announcements   CourseAnnouncement[]
  quizzes         CourseQuiz[]
  assignments     CourseAssignment[]
  liveClasses     CourseLiveClass[]
  certificates    CourseCertificate[]
  refundRequests  CourseRefundRequest[]
  views           CourseListingView[]
  @@index([status])
  @@index([category])
  @@index([categoryId])
  @@index([tutorId])
  @@index([isFeatured])
  @@index([slug])
}

model CourseCategory {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  iconKey     String?
  color       String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  subcategories CourseSubcategory[]
  courses     Course[]
  @@index([isActive])
  @@index([order])
}

model CourseSubcategory {
  id         String   @id @default(cuid())
  categoryId String
  category   CourseCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  slug       String
  name       String
  order      Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  courses    Course[]
  @@unique([categoryId, slug])
  @@index([categoryId])
}

model CourseModule {
  id          String   @id @default(cuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title       String
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lessons     CourseLesson[]
  @@index([courseId])
}

model CourseLesson {
  id           String   @id @default(cuid())
  courseId     String
  course       Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  moduleId     String?
  module       CourseModule? @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  title        String
  description  String?
  content      String?  @db.Text
  videoUrl     String?
  subtitlesUrl String?
  transcript   String?  @db.Text
  duration     Int      @default(0)
  order        Int
  isFree       Boolean  @default(false)
  isPreview    Boolean  @default(false)
  lessonType   CourseLessonType @default(VIDEO)
  resources    Json?
  quizId       String?
  quiz         CourseQuiz? @relation("LessonQuiz", fields: [quizId], references: [id], onDelete: SetNull)
  assignmentId String?
  assignment   CourseAssignment? @relation("LessonAssignment", fields: [assignmentId], references: [id], onDelete: SetNull)
  liveClassId  String?
  liveClass    CourseLiveClass? @relation("LessonLive", fields: [liveClassId], references: [id], onDelete: SetNull)
  progress     CourseLessonProgress[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@index([courseId])
  @@index([moduleId])
}

model CourseEnrollment {
  id              String   @id @default(cuid())
  courseId        String
  course          Course   @relation(fields: [courseId], references: [id])
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  progress        Int      @default(0)
  completedLessons String[] @default([])
  completedAt     DateTime?
  pricePaid       Float    @default(0)
  couponCode      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lessonProgress  CourseLessonProgress[]
  refundRequests  CourseRefundRequest[]
  @@unique([courseId, userId])
  @@index([userId])
}

model CourseLessonProgress {
  id             String   @id @default(cuid())
  enrollmentId   String
  enrollment     CourseEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lessonId       String
  lesson         CourseLesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  watchedSeconds Int      @default(0)
  totalSeconds   Int      @default(0)
