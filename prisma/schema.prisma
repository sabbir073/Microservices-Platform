  following   User     @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  // When this follow was created by an admin's bulk-boost operation. Null
  // means the follow is organic (real user-initiated).
  boostBatchId String?
  boostBatch   FollowerBoostBatch? @relation(fields: [boostBatchId], references: [id], onDelete: SetNull)
  @@unique([followerId, followingId])
