  children    Location[] @relation("LocationHierarchy")
  name        String
  // STATE | REGION | DIVISION | SUB_DIVISION | DISTRICT | SUB_DISTRICT | CITY | VILLAGE
  type        String
  postalCode  String?
  metadata    Json?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  @@unique([countryId, parentId, name, type])
  @@index([countryId, type, isActive])
  @@index([parentId, type, isActive])
  @@index([name])
}

